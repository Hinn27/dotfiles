    layout {
        gaps 10 // Gap between windows
        center-focused-column "on-overflow" // Don’t auto-center focused column

        background-color "transparent" // <- needed for noctalia-shell to set wallpaper

        preset-column-widths {
            proportion 0.33333
            proportion 0.5
            proportion 0.66667
    }

        struts 
    border {
        off

        width 2
    }
    focus-ring {
        off

        width 2
    }
}
