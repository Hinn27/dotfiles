include "./cfg/animation.kdl"
include "./cfg/autostart.kdl"
include "./cfg/keybinds.kdl"
include "./cfg/input.kdl"
include "./cfg/display.kdl"
include "./cfg/layout.kdl"
include "./cfg/rules.kdl"
include "./cfg/misc.kdl"
spawn-sh-at-startup "fcitx5 -d"
spawn-at-startup "kitty"
output "HDMI-A-1" {
    mode "1920x1080@200.000"

    scale 1.0

    transform "normal"
    position x=0 y=0
}
output "eDP-1" {
    mode "1920x1080@143.998"

    scale 1.0

    transform "normal"
    position x=-1920 y=0
}

blur {
    passes 3

    noise 0.04

    saturation 1.2000000000000002
}
