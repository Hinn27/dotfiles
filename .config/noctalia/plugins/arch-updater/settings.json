{
  "systemCmd": "checkupdates 2>/dev/null",
  "aurCmd": "paru -Qu 2>/dev/null",
  "updateCmd": "kitty -e bash -c 'echo \"Updating System...\";paru; flatpak update; read -n 1 -p \"Press any key to exit...\"'",
  "aurHomepageCmd": "LC_ALL=C paru -Si {id} 2>/dev/null | awk '/^URL/ {print $3}'",
  "flatpak": true,
  "noctalia": true,
  "toast": true,
  "desktopTip": true,
  "hideOnEmpty": true,
  "refreshTimer": true,
  "refreshInterval": 720,
  "iconName": "arrow-big-down-lines",
  "useDistroLogo": true,
  "customIconPath": "",
  "boldText": true,
  "enableColorization": false,
  "iconColor": "none",
  "boldVer": true,
  "tooltip": true,
  "closeButton": true,
  "closeOnSettings": false,
  "panelTooltip": true,
  "panelContext": true,
  "boldVerPanel": true,
  "boldVerDesktop": true,
  "hoverTip": true
}
